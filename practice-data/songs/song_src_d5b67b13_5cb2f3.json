  "lyrics": [
    {
      "id": "l1",
      "start": 15.87,
      "end": 19.78,
      "text": "손끝이 시리더니 벌써 봄이 왔네",
      "translation": "指尖才剛感到冰冷，春天已經來了",
      "confidence": 0.9,
      "segments": [],
      "notes": []
    },
    {
      "id": "l2",
      "start": 19.78,
      "end": 23.43,
      "text": "꿈같은 바람이 불어 곳곳에",
      "translation": "像夢一樣的風，吹遍每個角落",
      "confidence": 0.9,
      "segments": [],
      "notes": []
    },
    {
      "id": "l3",
      "start": 23.43,
      "end": 28.04,
      "text": "여느 때 와는 다른 듯한 이 기분이 반가워",
      "translation": "這份與平時不同的心情，讓我感到欣喜",
      "confidence": 0.9,
      "segments": [],
      "notes": []
    },
    {
      "id": "l4",
      "start": 28.04,
      "end": 31.48,
      "text": "내일은 좀 다른 날이 되려나",
      "translation": "明天會不會成為有點不同的一天呢",
      "confidence": 0.9,
      "segments": [],
      "notes": []
    },
    {
      "id": "l5",
      "start": 31.48,
      "end": 34.86,
      "text": "어둠의 그림자 깊은 이 밤에 남겨진",
      "translation": "在黑暗陰影深處的這一夜裡留下的",
      "confidence": 0.9,
      "segments": [],
      "notes": []
    },
    {
      "id": "l6",
      "start": 34.86,
      "end": 36.62,
      "text": "달이 달이 밝아와",
      "translation": "月亮，月亮漸漸明亮",
      "confidence": 0.9,
      "segments": [],
      "notes": []
    },
    {
      "id": "l7",
      "start": 36.62,
      "end": 38.67,
      "text": "빛을 그리고 있어",
      "translation": "正在描繪著光",
      "confidence": 0.9,
      "segments": [],
      "notes": []
    },
    {
      "id": "l8",
      "start": 38.67,
      "end": 40.52,
      "text": "내 몸에서 널 뺀 만큼",
      "translation": "就像從我身體裡抽離了你那麼多",
      "confidence": 0.9,
      "segments": [],
      "notes": []
    },
    {
      "id": "l9",
      "start": 40.52,
      "end": 43.66,
      "text": "욕조에 물이 미련이 되어 넘쳐흘러",
      "translation": "浴缸裡的水化作眷戀滿溢而出",
      "confidence": 0.9,
      "segments": [],
      "notes": []
    },
    {
      "id": "l10",
      "start": 43.66,
      "end": 46.1,
      "text": "한숨이 가득 그 공간을 채워",
      "translation": "嘆息填滿了那個空間",
      "confidence": 0.9,
      "segments": [],
      "notes": []
    },
    {
      "id": "l11",
      "start": 46.1,
      "end": 50.38,
      "text": "새벽이 찾아오면",
      "translation": "當凌晨到來時",
      "confidence": 0.9,
      "segments": [],
      "notes": [
        {
          "type": "chant",
          "mode": "standalone",
          "label": "chant",
          "text": "오면",
          "placement": "insert-at",
