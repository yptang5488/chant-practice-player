    {
      "id": "l21",
      "start": 87.23,
      "end": 91.53,
      "text": "겨울이 지나고 또다시 꽃은 피고",
      "translation": "冬天過去，花又再次盛開",
      "confidence": 0.9,
      "segments": [],
      "notes": []
    },
    {
      "id": "l22",
      "start": 91.53,
      "end": 95.14,
      "text": "따뜻한 공기 냄새가 날 감싸",
