            "charEnd": 8
          },
          "romanizedText": "omyeon"
        }
      ]
    },
    {
      "id": "l12",
      "start": 50.38,
      "end": 55.83,
      "text": "혼자 남겨질 때면",
      "translation": "當只剩我一個人時",
      "confidence": 0.9,
      "segments": [],
      "notes": []
    },
    {
      "id": "l13",
      "start": 55.83,
      "end": 59.66,
      "text": "Starry night 별이 빛나는 밤",
